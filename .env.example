# IB Connection Settings
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# Watchlist - comma separated symbols
WATCHLIST=NVDA,TSLA,AAPL,SPY,QQQ

# Logging
LOG_LEVEL=INFO

# Anthropic API (for natural-language rule creation)
ANTHROPIC_API_KEY=your_anthropic_api_key

# QA only: enables POST /api/rules/{rule_id}/trigger-test for manual rule
# triggering without waiting for real market conditions. Leave unset/false
# in production.
ENABLE_TEST_TRIGGER=false
